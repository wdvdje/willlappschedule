{
  "name": "TimeScape Planner",
  "short_name": "TimeScape",
  "description": "Your personal schedule, tasks, and life planner — calendar, habits, meals, gym, work earnings, and more.",
  "start_url": "index.html#calendar",
  "id": "timescape-planner",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui"],
  "launch_handler": { "client_mode": "navigate-existing" },
  "orientation": "any",
  "background_color": "#f2f2f7",
  "theme_color": "#007AFF",
  "categories": ["productivity", "lifestyle"],
  "handle_links": "preferred",
  "edge_side_panel": { "preferred_width": 480 },
  "prefer_related_applications": false,
  "screenshots": [],
  "shortcuts": [
    {
      "name": "Today",
      "short_name": "Today",
      "description": "Jump to today's view",
      "url": "index.html#today",
      "icons": [{ "src": "assets/shortcuts/shortcut-today.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Calendar",
      "short_name": "Calendar",
      "description": "Open the calendar",
      "url": "index.html#calendar",
      "icons": [{ "src": "assets/shortcuts/shortcut-calendar.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Tasks",
      "short_name": "Tasks",
      "description": "View your tasks",
      "url": "index.html#tasks",
      "icons": [{ "src": "assets/shortcuts/shortcut-tasks.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Inbox",
      "short_name": "Inbox",
      "description": "Check your inbox",
      "url": "index.html#inbox",
      "icons": [{ "src": "assets/shortcuts/shortcut-inbox.png", "sizes": "96x96", "type": "image/png" }]
    },
    {
      "name": "Reminders",
      "short_name": "Reminders",
      "description": "View your reminders",
      "url": "index.html#reminders",
      "icons": [{ "src": "assets/shortcuts/shortcut-reminders.png", "sizes": "96x96", "type": "image/png" }]
    }
  ],
  "icons": [
    {
      "src": "assets/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "assets/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "assets/icon.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any"
    }
  ]
}
